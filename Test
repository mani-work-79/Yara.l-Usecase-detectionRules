rule BRCM_235_Schedule_Task_with_Rundll32_Command_Trigger {
meta:
    name = "BRCM_235_Schedule_Task_with_Rundll32_Command_Trigger"
    author = "Deloitte"
    description = "Detects the creation of scheduled tasks in Windows that utilize the rundll32 command to execute payloads. This analytic leverages Windows Security EventCode 4698, which logs scheduled task creation, and filters for tasks set to launch via rundll32. This method is commonly used by malware (e.g., TrickBot) for persistence or further payload delivery. If confirmed malicious, it may facilitate data theft, ransomware, or continued compromise. Prompt investigation is recommended."
    severity = "High"
    mitre_ttp = "{'T1053.005': 'Scheduled Task/Job: Scheduled Task', 'T1218.011': 'Signed Binary Proxy Execution: Rundll32'}"
    reference_lists = "NA"
    log_dependencies = "WINEVTLOG"
    reference = "https://whitehat.eu/incident-response-case-study-featuring-ryuk-and-trickbot-part-2/"
    usecase = "Detection of potentially malicious scheduled tasks leveraging the rundll32 binary for persistence or execution of additional payloads."
events:
    (
        $e.metadata.log_type = "WINEVTLOG" AND
        $e.metadata.product_event_type = "4698" AND
        (
            ($e.principal.process.command_line = /rundll32/ nocase) OR ($e.target.process.command_line = /rundll32/ nocase)
        )
    )
    $e.principal.hostname = $Hostname
match:
    $Hostname over 15m
condition:
    $e
}


rule BRCM_222_Windows_RemoteInteractive_Login_Failures {

meta:

    name = "BRCM_222_Windows_RemoteInteractive_Login_Failures"
    author = "Deloitte"
    description = "Detects three or more Windows RemoteInteractive login failures (event 4625, auth_detail 10) by the same user from the same IP address within one hour."
    severity = "Medium"
    mitre_ttp = "{'T1110': 'Brute Force'}"
    mitre_tactics = "Credential Access"
    log_dependencies = "WINEVTLOG"

events:

    $e.metadata.log_type = "WINEVTLOG" AND
    $e.metadata.product_event_type = "4625" AND
    $e.extensions.auth.auth_details = "10" AND
    $e.target.user.userid != "" AND
    $e.principal.ip != "" AND 
    $e.principal.ip = $ip AND
    $e.target.user.userid = $user

match:
    $ip, $user over 1h

condition:
    #e >= 3

}


