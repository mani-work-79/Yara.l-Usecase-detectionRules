rule windows_event_log_cleared {
  meta:
    description = "Detects the clearing of Windows event logs (Security Event ID 1102 or System Event ID 104), which may indicate an attempt to cover tracks by an adversary."
    author = "detections.ai"
    date = "2026-03-30"
    tactic = "TA0005"
    technique = "T1070.001"
    tags = "WINDOWS, DEFENSE_EVASION, LOG_CLEARING"
    false_positives = "Legitimate system administration tasks, automated log maintenance scripts, or server provisioning processes."

  events:
    // Ensure event type is valid to optimize query performance
    $event.metadata.event_type != "EVENT_TYPE_UNSPECIFIED"

    // Target Windows Security log clearing (1102) and System log clearing (104)
    (
      $event.metadata.product_event_type = "1102" or
      $event.metadata.product_event_type = "104"
    )
    
    // Suggestion for False Positives (Medium Sensitivity): 
    // Filter out known authorized automation accounts or specific maintenance subnets here.
    // Example: $event.principal.user.userid != "svc_log_maintenance"

    // Extract device/dest and user into match variables for correlation
    $event.principal.hostname = $hostname
    $event.principal.user.userid = $user

  match:
    $hostname, $user over 5m

  outcome:
    $risk_score = 65
    $event_count = count($event.metadata.id)
    
    // Mapping requested conceptual fields to standard UDM outcome variables
    $event_codes = array_distinct($event.metadata.product_event_type)
    $dvc_hostname = array_distinct($event.principal.hostname)
    $dest_ip = array_distinct($event.target.ip)
    $user_id = array_distinct($event.principal.user.userid)
    
    // Extracting contextual fields for action, app, and change_type mapping
    $change_type = array_distinct($event.metadata.event_type)
    $app_name = array_distinct($event.metadata.product_name)
    $action_taken = array_distinct($event.security_result.action)

  condition:
    $event
    
  options:
    // Allow zero values in case the user ID is not populated in System Event ID 104 logs
    allow_zero_values = true
}
