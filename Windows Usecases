rule windows_event_log_cleared
{
    meta:
        rule_name = "Windows Event Log Cleared"
        description = "Detects the clearing of Windows event logs, including Security Event ID 1102 and System Event ID 104. This behavior may indicate an attempt by an adversary to evade detection by removing forensic evidence."
        author = "Deloitte"
        mitre_attack_tactic = "Defense Evasion"
        mitre_attack_technique = "Indicator Removal on Host: Clear Windows Event Logs (T1070.001)"
        tactic = "TA0005"
        technique = "T1070.001"
        type = "Alert"
        data_source = "Windows"
        severity = "Medium"
        priority = "Medium"
        known_false_positives = "Legitimate system administration activities, automated log maintenance, or server provisioning processes."
    events:
        (
            $e.metadata.product_event_type = "1102" OR
            $e.metadata.product_event_type = "104"
        )
        $e.principal.hostname = $hostname
    match:
        $hostname over 5m
    outcome:
        $event_codes = array_distinct($e.metadata.product_event_type)
        $dvc_hostname = array_distinct($e.principal.hostname)
        $dest_ip = array_distinct($e.target.ip)
        $user_id = array_distinct($e.principal.user.userid)
    condition:
        $e
}

