rule windows_remoteinteractive_login_failures
{
    meta:
        rule_name = "Windows RemoteInteractive Login Failures"
        description = "Detects multiple failed Windows RemoteInteractive login attempts for the same user originating from the same IP address within a one-hour window. This behavior may indicate brute-force attempts targeting remote access."
        author = "Deloitte"
        mitre_attack_tactic = "Credential Access"
        mitre_attack_technique = "Brute Force (T1110)"
        tactic = "TA0006"
        technique = "T1110"
        type = "Alert"
        data_source = "Windows"
        severity = "Medium"
        priority = "Medium"
events:
    $e.metadata.log_type = "WINEVTLOG" AND
    $e.metadata.product_event_type = "4625" AND
    $e.extensions.auth.auth_details = "10" AND
    $e.target.user.userid != "" AND
    $e.principal.ip != "" AND 
    $e.principal.ip = $ip AND
    $e.target.user.userid = $user
match:
    $ip, $user over 1h
condition:
    #e >= 3
}

