rule windows_event_log_access_tampering_via_registry
{
    meta:
    rule_name = "Windows Event Log Access Tampering via Registry"
    description = "Detects changes to the Windows EventLog channel permission values. It focuses on changes to the Security Descriptor Definition Language (SDDL) string, as modifications to these values can restrict access to specific users or groups, potentially aiding in defense evasion by controlling who can view or modify a event log channel. Upon execution, the user shouldn't be able to access the event log channel via the event viewer or via utilities such as Get-EventLog or wevtutil"
    author = "Deloitte"
    mitre_attack_tactic = "Persistence, Privilege Escalation"
    mitre_attack_technique = "Boot or Logon Autostart Execution: Registry Run Keys / Startup Folder"
    tactic = "TA0003, TA0004"
    technique = "T1574.001"
    mitre_attack_url = "https://attack.mitre.org/techniques/T1574/001/"
    type = "Alert"
    data_source = "Windows"
    severity = "Medium"
    priority = "Medium" 
  events:
   (
    $event.metadata.event_type = "REGISTRY_MODIFICATION" 
    and (
      (
        re.regex($event.target.registry.registry_key, `\\SYSTEM\\controlset\\Services\\EventLog\\System`) nocase and 
        (re.regex($event.target.registry.registry_key, `\\CustomSD$`) nocase or $event.target.registry.registry_value_name = "CustomSD")
      )
      or (
        (
          re.regex($event.target.registry.registry_key, `\\Policies\\Microsoft\\Windows\\EventLog\\Setup`) nocase or 
          re.regex($event.target.registry.registry_key, `\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels`) nocase
        )
        and 
        (re.regex($event.target.registry.registry_key, `\\ChannelAccess$`) nocase or $event.target.registry.registry_value_name = "ChannelAccess")
      )
    )
    and (
      re.regex($event.target.registry.registry_value_data, `D:\(D;`) nocase
      or (
        re.regex($event.target.registry.registry_value_data, `D:\(`) nocase and 
        re.regex($event.target.registry.registry_value_data, `\)\(D;`) nocase
      )
    )
  )
  outcome:
        $key_asset = array_distinct($event.principal.hostname )
        $principal_command_line = array_distinct($event.principal.process.command_line)
        $target_command_line = array_distinct($event.target.process.command_line)
        $principal_file_path = array_distinct($event.principal.process.file.full_path)
        $target_file_path = array_distinct($event.target.process.file.full_path)
        $target_user_email_address = array_distinct($event.target.user.email_addresses)
        $target_registry_key = array_distinct($event.target.registry.registry_key)
        $target_registry_value_name = array_distinct($event.target.registry.registry_value_name)
        $target_registry_value_data = array_distinct($event.target.registry.registry_value_data)
        $log_type = array_distinct($event.metadata.log_type)

  condition:
    $event
}
