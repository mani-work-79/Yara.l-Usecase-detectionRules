rule windows_scheduled_task_created_with_rundll32_command
{
    meta:
        rule_name = "Windows Scheduled Task Created with Rundll32 Command"
        description = "Detects the creation of scheduled tasks in Windows that execute commands using the rundll32 binary. This technique is commonly abused by malware to establish persistence or execute additional payloads and may indicate malicious activity requiring prompt investigation."
        author = "Deloitte"
        mitre_attack_tactic = "Persistence, Defense Evasion"
        mitre_attack_technique = "Scheduled Task/Job: Scheduled Task (T1053.005), Signed Binary Proxy Execution: Rundll32 (T1218.011)"
        tactic = "TA0003, TA0005"
        technique = "T1053.005, T1218.011"
        mitre_attack_url = "https://attack.mitre.org/techniques/T1053/005/"
        type = "Alert"
        data_source = "Windows"
        severity = "Medium"
        priority = "Medium"
events:
    (
        $e.metadata.log_type = "WINEVTLOG" AND
        $e.metadata.product_event_type = "4698" AND
        (
            ($e.principal.process.command_line = /rundll32/ nocase) OR ($e.target.process.command_line = /rundll32/ nocase)
        )
    )
    $e.principal.hostname = $Hostname
match:
    $Hostname over 15m
condition:
    $e
}
